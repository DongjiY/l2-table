{
  "name": "l2-table-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "sample/*"
  ],
  "scripts": {
    "prepare": "simple-git-hooks",
    "build": "pnpm --filter './packages/*' run build",
    "test": "pnpm --filter './packages/*' run --if-present test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "dev": "pnpm --filter @dongjiy/l2-table run dev",
    "serve": "serve . -l 3000",
    "dev:all": "concurrently \"pnpm --filter @dongjiy/l2-table run dev\" \"pnpm run serve\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "pretty-quick": "^4.2.2",
    "serve": "^14.2.5",
    "simple-git-hooks": "^2.13.1",
    "ts-jest": "^29.4.9"
  }
}
