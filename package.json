{
  "name": "l2-table-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "sample/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace l2-table",
    "serve": "serve . -l 3000",
    "dev:all": "concurrently \"npm run dev --workspace l2-table\" \"npm run serve\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "serve": "^14.2.5"
  }
}
