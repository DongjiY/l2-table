{
  "name": "l2-table",
  "type": "module",
  "version": "1.0.0",
  "description": "fast, observable-driven, canvas tables",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --format esm --dts",
    "dev": "tsup --watch --format esm --dts",
    "serve": "serve . -l 3000",
